---
// src/pages/firmware/[...slug].astro
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

export async function getStaticPaths() {
  const allFirmware = await Astro.glob("../../content/firmware/*.{md,mdx}");
  
  return allFirmware.map(firmware => {
    const filePath = firmware.file;
    // Декодируем slug из имени файла
    let slug = filePath.split('/').pop()?.replace(/\.(md|mdx)$/, '') || '';
    // Заменяем пробелы на дефисы, убираем спецсимволы
    slug = slug.replace(/\s+/g, '-').toLowerCase();
    
    return {
      params: { slug },
      props: { firmware, originalSlug: slug },
    };
  });
}

const { firmware, originalSlug } = Astro.props;
const currentSlug = originalSlug || Astro.params.slug;

if (!firmware) {
  return Astro.redirect("/404");
}

const { frontmatter, Content } = firmware;
---

<Layout title={`${frontmatter.title} — Прошивка`} description={frontmatter.description}>
  <Header />
  
  <main class="max-w-3xl mx-auto px-4 py-8">
    <div class="mb-4">
      <a href="/firmware/1" class="text-blue-500 hover:underline">← Назад ко всем файлам</a>
    </div>
    
    <div data-pagefind-body>
      <div class="border rounded-lg p-6 border-gray-200 dark:border-gray-800">
        <h1 class="text-2xl font-bold" data-pagefind-filter="title">{frontmatter.title}</h1>
        {/* Кнопка скачивания */}
<div class="my-4">
  <a
    href={frontmatter.fileUrl}
    download
    class="border border-gray-200 dark:border-gray-700 hover:border-blue-500 px-4 py-2 rounded-lg text-sm text-center transition"
                    data-pagefind-ignore
  >
    <span>⬇️</span> Скачать прошивку ({frontmatter.fileSize})
  </a>
</div>
        <div class="flex gap-2 my-4">
          <span class="bg-gray-100 dark:bg-gray-800 px-3 py-1 rounded text-sm" data-pagefind-filter="device">
            💽 {frontmatter.device}
          </span>
          <span class="bg-gray-100 dark:bg-gray-800 px-3 py-1 rounded text-sm" data-pagefind-filter="version">
            📌 {frontmatter.version}
          </span>
        </div>
        
        <div class="prose dark:prose-invert max-w-none" data-pagefind-filter="description">
          <Content />
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>